# indexit configuration
#
# Values in this file OVERRIDE the process environment for keys present here.
# Shell-exported variables are used only as a fallback for keys not listed.
# To run with env-only (e.g. in CI), pass `--env-file=""`.

# --- GitHub (optional) ---
GITHUB_TOKEN=https://github.com/settings/tokens

# --- Telegram credentials (required by `indexit telegram`) ---
TELEGRAM_API_ID=https://my.telegram.org/apps
TELEGRAM_API_HASH=https://my.telegram.org/apps

# --- Logging ---
# Levels: error | warn | info | debug | trace. Overridden by -v / -q flags.
# INDEXIT_LOG_LEVEL=info

# --- Proxy (optional) ---
# Either set the full URL form (takes precedence over discrete vars):
#   socks5://user:pass@host:1080
#   mtproto://host:443?secret=<hex>
#   http://host:3128
# INDEXIT_PROXY_URL=
#
# ...or use the discrete form:
# INDEXIT_PROXY_TYPE=socks5     # socks5 | mtproto | http
# INDEXIT_PROXY_HOST=
# INDEXIT_PROXY_PORT=
# INDEXIT_PROXY_USER=
# INDEXIT_PROXY_PASS=
# INDEXIT_PROXY_SECRET=         # required for mtproto (hex)
#
# HTTPS_PROXY / NO_PROXY are NOT consulted: MTProto is not HTTPS, and reusing
# those names would silently break tools that set them for unrelated purposes.
